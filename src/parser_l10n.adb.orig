-----------------------------------------------------------------------------
--  PARSE L10N DAY (Day of Week)
--
-- Syntax: l10n.day( d );
-- Source: N/A
-----------------------------------------------------------------------------

#if L10N
procedure ParseL10NDay( result : out storage; kind : out identifier ) is
  dayExpr : storage;
  dayKind : identifier;
  day     : positive;
begin
  kind := uni_string_t;
  expect( l10n_day_t );
  ParseSingleNumericParameter( l10n_day_t, dayExpr, dayKind, positive_t );
  if isExecutingCommand then
     result := nullStorage;
     if metaTagOk( l10n_day_t, dayExpr ) then
        begin
           day := positive( to_numeric( dayExpr.value ) );
           case day is
           when 1 => result := storage'( day_1, noMetaTag, dayExpr.policyMetaTags );
           when 2 => result := storage'( day_2, noMetaTag, dayExpr.policyMetaTags );
           when 3 => result := storage'( day_3, noMetaTag, dayExpr.policyMetaTags );
           when 4 => result := storage'( day_4, noMetaTag, dayExpr.policyMetaTags );
           when 5 => result := storage'( day_5, noMetaTag, dayExpr.policyMetaTags );
           when 6 => result := storage'( day_6, noMetaTag, dayExpr.policyMetaTags );
           when 7 => result := storage'( day_7, noMetaTag, dayExpr.policyMetaTags );
           when others =>
              err( +"day is 1..7" );
           end case;
        exception when others =>
           err_exception_raised;
        end;
     end if;
  end if;
end ParseL10NDay;
#else
procedure ParseL10NDay( result : out storage; kind : out identifier ) renames not_configured;
#end if;


