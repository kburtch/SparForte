---------------------------------------------------------
--
-- PARSE THE L10N PACKAGE
--
---------------------------------------------------------

#if not L10N
procedure not_configured( result : out storage; kind : out identifier ) is
begin
  result := nullStorage;
  kind := universal_t;
  err( +"l10n support not configured" );
end not_configured;

procedure not_configured is
begin
  err( +"l10n support not configured" );
end not_configured;
#end if;

-----------------------------------------------------------------------------
--  PARSE L10N SETLOCALE
--
-- Syntax: l10n.setlocale;
-- Source: N/A
-----------------------------------------------------------------------------

#if L10N
procedure ParseL10NSetLocale is
  catExpr : storage;
  cat_kind :identifier;
  locExpr : storage;
  loc_kind :identifier;
begin
  expect( l10n_setlocale_t );
  ParseFirstNumericParameter( l10n_setlocale_t, catExpr, cat_kind, l10n_locale_category_t );
  ParseLastStringParameter( l10n_setlocale_t, locExpr,loc_kind );
  if isExecutingCommand then
     if metaTagOk( l10n_setlocale_t, locExpr ) then
        -- checking errno is not reliable.  On first attempt to use an invalid
        -- locale, errono will be 2 (file not found), probably because of another
        -- function called by setlocale.  However, setlocale itself does not
        -- return an error number.
        setlocale( locale_category( to_numeric( catExpr.value ) ), to_string( locExpr.value ) );
     end if;
  end if;
end ParseL10NSetLocale;
#else
procedure ParseL10NSetLocale renames not_configured;
#end if;


-----------------------------------------------------------------------------
--  PARSE L10N GETLOCALE
--
-- Syntax: l10n.getlocale;
-- Source: N/A
-----------------------------------------------------------------------------

#if L10N
procedure ParseL10NGetLocale( result : out storage; kind : out identifier ) is
  catExpr : storage;
  cat_kind :identifier;
begin
  kind := string_t;
  expect( l10n_getlocale_t );
  ParseSingleNumericParameter( l10n_getlocale_t, catExpr, cat_kind, l10n_locale_category_t );
  if isExecutingCommand then
     -- setlocale does not return an error number
     result := storage'( getlocale( locale_category( to_numeric( catExpr.value ) ) ), noMetaTag, sparMetaTags );
  end if;
end ParseL10NGetLocale;
#else
procedure ParseL10NGetLocale( result : out storage; kind : out identifier ) renames not_configured;
#end if;

