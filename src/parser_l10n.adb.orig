        begin
           mon := positive( to_numeric( monExpr.value ) );
           case mon is
           when  1 => result := storage'(mon_1, noMetaTag, monExpr.policyMetaTags);
           when  2 => result := storage'(mon_2, noMetaTag, monExpr.policyMetaTags);
           when  3 => result := storage'(mon_3, noMetaTag, monExpr.policyMetaTags);
           when  4 => result := storage'(mon_4, noMetaTag, monExpr.policyMetaTags);
           when  5 => result := storage'(mon_5, noMetaTag, monExpr.policyMetaTags);
           when  6 => result := storage'(mon_6, noMetaTag, monExpr.policyMetaTags);
           when  7 => result := storage'(mon_7, noMetaTag, monExpr.policyMetaTags);
           when  8 => result := storage'(mon_8, noMetaTag, monExpr.policyMetaTags);
           when  9 => result := storage'(mon_9, noMetaTag, monExpr.policyMetaTags);
           when 10 => result := storage'(mon_10, noMetaTag, monExpr.policyMetaTags);
           when 11 => result := storage'(mon_11, noMetaTag, monExpr.policyMetaTags);
           when 12 => result := storage'(mon_12, noMetaTag, monExpr.policyMetaTags);
           when others =>
